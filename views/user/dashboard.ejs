<% layout("/layouts/boilerplate") %>
<% const role = (currentUser && currentUser.role) ? currentUser.role : "donor"; %>

<style>
  .dashboard-wrapper { padding: 40px; font-family: sans-serif; }
  .welcome-banner {
    background: #e6004e;
    color: white;
    padding: 30px;
    border-radius: 15px;
    margin-bottom: 30px;
  }
  .req-card {
    background: white;
    border: 1px solid #eee;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    border-left: 5px solid #e6004e;
    margin-bottom: 20px;
  }
  .status-tag {
    float: right;
    background: #fff3cd;
    color: #856404;
    padding: 5px 10px;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: bold;
  }
</style>

<div class="dashboard-wrapper">
  <div class="welcome-banner">
    <h1>Hi, <%= currentUser.username %>! 👋</h1>
    <p>
      <strong><%= role === "donee" ? "Donee" : "Donor" %></strong> account
      | Blood Group: <strong><%= currentUser.bloodGroup || 'O+' %></strong>
    </p>
  </div>

  <h3 style="margin-bottom: 20px;">
    <%= role === "donee" ? "Your Blood Requests:" : "Your Active Donation Requests:" %>
  </h3>

  <% if(donations.length === 0) { %>
    <p>
      <%= role === "donee" ? "No blood requests yet." : "No active donation requests." %>
      <a href="/listings">Find a blood bank</a>
    </p>
  <% } else { %>
    <div class="requests-list">
      <% donations.forEach(newDonation => { %>
        <div class="req-card">
          <% const hospital = newDonation.hospital || {}; %>
          <% const hospitalName = hospital.name || "Unknown Hospital"; %>
          <% const hospitalPlace = hospital.location || hospital.address || "Location not available"; %>
          
          <span class="status-tag"><%= newDonation.status %></span>
          <h4>
            <%= role === "donee" ? "You requested blood at" : "You have active donation request at" %>:
            <%= hospitalName %>
          </h4>
          <p style="color: #636e72; margin-top: 10px;">
            <i class="fas fa-location-dot"></i> <%= hospitalPlace %><br>
            <i class="fas fa-tint"></i> Blood Group: <%= currentUser.bloodGroup || 'O+' %>
          </p>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
