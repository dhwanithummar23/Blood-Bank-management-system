<% layout("/layouts/boilerplate") %>

<div
  style="
    background-color: #f8f9fa;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    padding: 20px;
  "
>
  <div
    style="
      background: white;
      width: 100%;
      max-width: 400px;
      padding: 40px;
      border-radius: 15px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
      text-align: center;
    "
  >
    <div
      style="
        width: 60px;
        height: 60px;
        background-color: #fff0f5;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 0 auto 20px auto;
      "
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="30"
        height="30"
        viewBox="0 0 24 24"
        fill="#e6004e"
      >
        <path
          d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
        />
      </svg>
    </div>

    <h2
      style="
        color: #333;
        margin: 0 0 10px 0;
        font-size: 1.6rem;
        font-weight: 700;
      "
    >
      Blood Bank Login
    </h2>
    <p style="color: #666; margin-bottom: 30px; font-size: 0.9rem">
      Administrative Portal Access
    </p>

    <form
      action="/login/bloodbank"
      method="POST"
      style="display: flex; flex-direction: column; gap: 15px; text-align: left"
    >
      <div>
        <label
          style="
            display: block;
            font-size: 0.8rem;
            font-weight: 700;
            color: #555;
            margin-bottom: 5px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
          "
          >Username</label
        >
        <input
          name="username"
          placeholder="Enter bank username"
          required
          style="
            width: 100%;
            padding: 12px;
            border: 1.5px solid #eee;
            border-radius: 8px;
            box-sizing: border-box;
            font-size: 1rem;
            outline: none;
            transition: border-color 0.3s;
          "
        />
      </div>

      <div>
        <label
          style="
            display: block;
            font-size: 0.8rem;
            font-weight: 700;
            color: #555;
            margin-bottom: 5px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
          "
          >Password</label
        >
        <input
          name="password"
          type="password"
          placeholder="Enter password"
          required
          style="
            width: 100%;
            padding: 12px;
            border: 1.5px solid #eee;
            border-radius: 8px;
            box-sizing: border-box;
            font-size: 1rem;
            outline: none;
          "
        />
      </div>

      <button
        type="submit"
        style="
          margin-top: 5px;
          width: 100%;
          background: #e6004e;
          color: #fff;
          border: none;
          padding: 12px;
          border-radius: 8px;
          font-size: 1rem;
          font-weight: 600;
          cursor: pointer;
        "
      >
        Login
      </button>
    </form>
  </div>
</div>
