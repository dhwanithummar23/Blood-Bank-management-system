<% layout("/layouts/boilerplate") %>
<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><%= bank.name %> Dashboard</h2>
    <a href="/listings/<%= bank._id %>/edit" class="btn btn-outline-danger">Edit Bank Details & Stock</a>
  </div>

  <div class="row mb-4">
    <div class="col-md-3 mb-2">
      <div class="card text-bg-light">
        <div class="card-body">
          <h6 class="card-title">Total Requests</h6>
          <h3><%= stats.total %></h3>
        </div>
      </div>
    </div>
    <div class="col-md-3 mb-2">
      <div class="card text-bg-warning">
        <div class="card-body">
          <h6 class="card-title">Pending</h6>
          <h3><%= stats.pending %></h3>
        </div>
      </div>
    </div>
    <div class="col-md-3 mb-2">
      <div class="card text-bg-success">
        <div class="card-body">
          <h6 class="card-title">Accepted</h6>
          <h3><%= stats.accepted %></h3>
        </div>
      </div>
    </div>
    <div class="col-md-3 mb-2">
      <div class="card text-bg-secondary">
        <div class="card-body">
          <h6 class="card-title">Rejected</h6>
          <h3><%= stats.rejected %></h3>
        </div>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <h5 class="card-title">Current Blood Stock</h5>
      <div class="row">
        <% for(let type in bank.available_blood_stock) { %>
          <div class="col-6 col-md-3 mb-2">
            <strong><%= type %>:</strong> <%= bank.available_blood_stock[type] %> Units
          </div>
        <% } %>
      </div>
      <p class="mt-3 mb-1"><strong>Address:</strong> <%= bank.address %></p>
      <p class="mb-1"><strong>Contact:</strong> <%= bank.phone %></p>
      <p class="mb-0"><strong>Timing:</strong> <%= bank.timing %></p>
    </div>
  </div>

  <h4 class="mb-3">Incoming User Requests</h4>
  <% if (donationRequests.length === 0) { %>
    <p>No user requests yet.</p>
  <% } else { %>
    <% donationRequests.forEach((reqItem) => { %>
      <div class="card mb-3">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <h5 class="mb-1"><%= reqItem.donor ? reqItem.donor.username : "Unknown user" %></h5>
              <p class="mb-1">
                Type:
                <strong><%= reqItem.requestType === "BloodRequest" ? "Blood Request (Donee)" : "Donation Request (Donor)" %></strong>
              </p>
              <p class="mb-1">Blood Group: <strong><%= reqItem.bloodGroup || "N/A" %></strong></p>
              <p class="mb-1">Location: <%= reqItem.donor ? reqItem.donor.location : "N/A" %></p>
              <p class="mb-0">Requested on: <%= reqItem.createdAt.toDateString() %></p>
            </div>
            <span class="badge text-bg-<%= reqItem.status === 'Accepted' ? 'success' : (reqItem.status === 'Rejected' ? 'secondary' : 'warning') %>"><%= reqItem.status %></span>
          </div>

          <% if (reqItem.status === "Pending") { %>
            <div class="mt-3 d-flex gap-2">
              <form method="POST" action="/bloodbank/donations/<%= reqItem._id %>/accept?_method=PUT">
                <button class="btn btn-success btn-sm">Accept</button>
              </form>
              <form method="POST" action="/bloodbank/donations/<%= reqItem._id %>/reject?_method=PUT">
                <button class="btn btn-outline-secondary btn-sm">Reject</button>
              </form>
            </div>
          <% } %>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>
