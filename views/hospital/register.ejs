<% layout("/layouts/boilerplate") %>

<div class="form-container">
  <div class="form-card">
    <div class="form-header">
      <h3>Hospital Registration</h3>
      <p>Create an account to send urgent blood requests to blood banks</p>
    </div>

    <form action="/register/hospital" method="POST" class="registration-form">
      <div class="input-group">
        <label for="name">Hospital Name</label>
        <input type="text" id="name" name="name" required placeholder="Enter hospital name" />
      </div>

      <div class="input-group">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" required placeholder="Choose username" />
      </div>

      <div class="input-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required placeholder="Create password" />
      </div>

      <div class="input-group">
        <label for="address">Address</label>
        <input type="text" id="address" name="address" required placeholder="Hospital address" />
      </div>

      <div class="input-group">
        <label for="phone">Phone</label>
        <input type="text" id="phone" name="phone" required placeholder="Contact number" />
      </div>

      <button type="submit" class="btn-submit">Register Hospital</button>

      <div class="form-footer">
        <p>Already registered? <a href="/login/hospital">Hospital Login</a></p>
      </div>
    </form>
  </div>
</div>
